import numpy as np
import random
import copy
import math
from typing import List, Tuple

class GeneticAlgorithm:
    def __init__(self, 
                 distance_matrix: np.ndarray,
                 demands: List[float],
                 time_windows: List[Tuple[float, float, float, float]],  # [a1, a2, b2, b1] fuzzy
                 service_times: List[float],
                 vehicle_capacity: float,
                 priority_levels: List[int],          # 1-5 scale
                 num_vehicles: int,
                 max_generations: int = 500,
                 population_size: int = 200,
                 crossover_rate: float = 0.8,
                 mutation_rate: float = 0.15):
        
        self.dist = distance_matrix
        self.demands = demands
        self.tw = time_windows
        self.service = service_times
        self.Q = vehicle_capacity
        self.priority = priority_levels
        self.n_vehicles = num_vehicles
        self.n_customers = len(demands) - 1  # exclude depot
        
        self.max_gen = max_generations
        self.pop_size = population_size
        self.cx_rate = crossover_rate
        self.mut_rate = mutation_rate
        
        self.best_solution = None
        self.best_fitness = float('inf')

    # --------------------- Fitness Function (Scalarized) ---------------------
    def evaluate_fitness(self, chromosome: List[int]) -> float:
        routes = self.decode_chromosome(chromosome)
        total_cost = 0.0
        total_emissions = 0.0
        total_freshness = 0.0
        n_served = 0

        for route in routes:
            if not route:
                continue
            load = sum(self.demands[i] for i in route)
            if load > self.Q:
                return float('inf')  # infeasible

            route_cost = 0.0
            route_emissions = 0.0
            arrival_time = 0.0

            prev = 0  # depot
            for cust in route:
                route_cost += self.dist[prev][cust]
                route_emissions += self.dist[prev][cust] * 0.25  # example factor
                arrival_time += self.dist[prev][cust] / 60.0  # assume 60 km/h

                # Fuzzy time window penalty
                a1, a2, b2, b1 = self.tw[cust]
                if arrival_time < a1:
                    penalty = (a1 - arrival_time) * self.priority[cust] * 50
                elif arrival_time > b1:
                    penalty = (arrival_time - b1) * self.priority[cust] * 100
                else:
                    penalty = 0

                route_cost += penalty
                arrival_time += self.service[cust]

                # Freshness using Arrhenius-Gompertz (simplified)
                freshness = 100 * math.exp(-0.002 * arrival_time)
                total_freshness += freshness * self.priority[cust]
                n_served += 1

                prev = cust

            # Return to depot
            route_cost += self.dist[prev][0]
            route_emissions += self.dist[prev][0] * 0.25
            total_cost += route_cost
            total_emissions += route_emissions

        avg_freshness = total_freshness / max(n_served, 1)

        # Scalarized fitness (lower is better)
        w_cost = 0.35
        w_emis = 0.35
        w_fresh = 0.30
        fitness = w_cost * total_cost + w_emis * total_emissions - w_fresh * avg_freshness

        return fitness

    # --------------------- Chromosome Decoding ---------------------
    def decode_chromosome(self, chromosome: List[int]) -> List[List[int]]:
        routes = []
        current_route = []
        for gene in chromosome:
            if gene == 0:  # vehicle separator
                if current_route:
                    routes.append(current_route)
                current_route = []
            else:
                current_route.append(gene)
        if current_route:
            routes.append(current_route)
        return routes

    # --------------------- Initialization ---------------------
    def initialize_population(self) -> List[List[int]]:
        population = []
        customers = list(range(1, self.n_customers + 1))
        for _ in range(self.pop_size):
            random.shuffle(customers)
            chrom = []
            for i in range(self.n_vehicles - 1):
                chrom.extend(customers[i*len(customers)//self.n_vehicles : (i+1)*len(customers)//self.n_vehicles])
                chrom.append(0)  # separator
            chrom.extend(customers[(self.n_vehicles-1)*len(customers)//self.n_vehicles:])
            population.append(chrom)
        return population

    # --------------------- Operators ---------------------
    def tournament_selection(self, population: List[List[int]], fitnesses: List[float], k=3):
        selected = random.sample(range(len(population)), k)
        best = min(selected, key=lambda i: fitnesses[i])
        return population[best]

    def ordered_crossover(self, parent1: List[int], parent2: List[int]) -> List[int]:
        size = len(parent1)
        start, end = sorted(random.sample(range(size), 2))
        offspring = [None] * size
        offspring[start:end] = parent1[start:end]
        
        ptr = end
        for gene in parent2:
            if gene not in offspring:
                while offspring[ptr % size] is not None:
                    ptr += 1
                offspring[ptr % size] = gene
        return offspring

    def mutate(self, chromosome: List[int]) -> List[int]:
        if random.random() < self.mut_rate:
            # Swap mutation
            i, j = random.sample(range(len(chromosome)), 2)
            chromosome[i], chromosome[j] = chromosome[j], chromosome[i]
        return chromosome

    # --------------------- Main GA Loop ---------------------
    def run(self):
        population = self.initialize_population()
        best_solution = None
        best_fitness = float('inf')

        for gen in range(self.max_gen):
            fitnesses = [self.evaluate_fitness(ind) for ind in population]
            
            new_population = []
            # Elitism
            best_idx = np.argmin(fitnesses)
            new_population.append(population[best_idx])
            
            while len(new_population) < self.pop_size:
                p1 = self.tournament_selection(population, fitnesses)
                p2 = self.tournament_selection(population, fitnesses)
                offspring = self.ordered_crossover(p1, p2)
                offspring = self.mutate(offspring)
                new_population.append(offspring)
            
            population = new_population
            
            current_best = min(fitnesses)
            if current_best < best_fitness:
                best_fitness = current_best
                best_solution = population[best_idx]
                
            if gen % 50 == 0:
                print(f"Generation {gen}: Best fitness = {best_fitness:.2f}")

        self.best_solution = best_solution
        self.best_fitness = best_fitness
        return best_solution, best_fitness


