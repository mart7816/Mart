# 2. Arrhenius-Gompertz freshness model
def freshness_decay(time_delivered, temp, base_shelf_life=1450, T_ref=4, Ea=80_000, R=8.314):
    # Simplified Arrhenius-Gompertz: freshness % = 100 * exp(-k * (t - t_ref))
    k = 1 / base_shelf_life * math.exp(-Ea / (R * (temp + 273.15))) * math.exp(Ea / (R * (T_ref + 273.15)))
    freshness = 100 * math.exp(-k * time_delivered)
    return max(0, freshness)

# 3. Objective functions
def calculate_cost(route, distances, fixed_cost=100, var_cost=1.0):
    return fixed_cost * len(route) + var_cost * sum(distances[i][j] for i, j in route)

def calculate_emissions(route, distances, emission_factor=0.2):
    return emission_factor * sum(distances[i][j] for i, j in route)

def calculate_freshness(routes, arrival_times, temps):
    freshness_sum = 0
    for route, times in zip(routes, arrival_times):
        for i, arrival in enumerate(times):
            freshness_sum += freshness_decay(arrival, temps[i])
    return freshness_sum / len(routes)  # average

